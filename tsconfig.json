{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "jsx": "react-jsx",

    "strict": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,

    "noEmit": true,
    "skipLibCheck": true,

    "types": ["vite/client"]
  },
  "include": ["resources/js/**/*"]
}